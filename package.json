{
  "name": "web-programming-lecture-homework",
  "private": true,
  "scripts": {
    "build:react": "esbuild src/react-crud.jsx --bundle --minify --outfile=assets/react-crud.js --format=esm --loader:.jsx=jsx --jsx=automatic",
    "build:axios": "esbuild src/axios-crud.jsx --bundle --minify --outfile=assets/axios-crud.js --format=esm --loader:.jsx=jsx --jsx=automatic",
    "build:calc": "esbuild react/calculator/src/main.jsx --bundle --minify --outfile=react/calculator/dist/app.js --format=esm --loader:.jsx=jsx --jsx=automatic",
    "build:ttt": "esbuild react/tictactoe/src/main.jsx --bundle --minify --outfile=react/tictactoe/dist/app.js --format=esm --loader:.jsx=jsx --jsx=automatic",
    "build:spa": "npm run build:calc && npm run build:ttt"
  },
  "dependencies": {
    "axios": "^1.7.9",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "esbuild": "^0.24.0"
  }
}
